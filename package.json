{
  "name": "ai-daily-report",
  "version": "1.0.0",
  "description": "My Remotion video",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@remotion/cli": "4.0.475",
    "@remotion/zod-types": "4.0.475",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.475",
    "zod": "4.3.6",
    "@remotion/tailwind-v4": "4.0.475",
    "tailwindcss": "4.0.0"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.475",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "check-data-json": "node scripts/check-data-json.mjs",
    "check-data-json:render": "node scripts/check-data-json.mjs --render",
    "tts": "node --env-file-if-exists=.env scripts/generate-tts.mjs",
    "tts:dry-run": "node --env-file-if-exists=.env scripts/generate-tts.mjs --dry-run",
    "tts:force": "node --env-file-if-exists=.env scripts/generate-tts.mjs --force",
    "prepare-report": "bun run check-data-json && bun run tts && bun run check-data-json:render",
    "predev": "bun run check-data-json:render",
    "dev": "remotion studio",
    "prebuild": "bun run check-data-json:render",
    "build": "remotion bundle",
    "upgrade": "remotion upgrade",
    "lint": "eslint src scripts && tsc"
  },
  "sideEffects": [
    "*.css"
  ]
}
