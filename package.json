{
  "name": "ai-daily-report",
  "version": "1.0.0",
  "description": "My Remotion video",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@remotion/cli": "4.0.475",
    "@remotion/tailwind-v4": "4.0.475",
    "@remotion/zod-types": "4.0.475",
    "ora": "^9.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.475",
    "tailwindcss": "4.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.475",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "ajv": "^8.20.0",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "check-data-json": "node scripts/checks/check-data-json.mjs",
    "check-data-json:render": "node scripts/checks/check-data-json.mjs --render",
    "check-icons": "node scripts/checks/check-icons.mjs",
    "val-schema": "bun run check-icons",
    "tts": "bun run check-data-json && node --env-file-if-exists=.env scripts/render/generate-tts.mjs",
    "tts:dry-run": "bun run check-data-json && node --env-file-if-exists=.env scripts/render/generate-tts.mjs --dry-run",
    "tts:force": "bun run check-data-json && node --env-file-if-exists=.env scripts/render/generate-tts.mjs --force",
    "prerss": "node scripts/archive/archive-check.mjs",
    "rss": "go -C ingest run .",
    "video:prepare": "node scripts/render/run-all.mjs",
    "reset": "node scripts/archive/reset.mjs",
    "rss:test": "go -C ingest test ./...",
    "archive": "node scripts/archive/archive.mjs",
    "comment": "node scripts/render/generate-comment.mjs",
    "bili:comment": "node scripts/publish/bili/bili-comment.mjs",
    "bili:stick": "node scripts/publish/bili/bili-stick.mjs",
    "prepare-report": "bun run tts && bun run check-data-json:render",
    "predev": "bun run check-data-json",
    "dev": "node scripts/render/dev.mjs",
    "dev:studio": "remotion studio",
    "prebuild": "bun run check-data-json:render",
    "build": "remotion bundle",
    "video:render": "bun run prepare-report && bunx remotion render AiDailyReport out/AiDailyReport.mp4",
    "render:cover": "bunx remotion still AiDailyReport out/cover.png --frame=45",
    "bili:meta": "node --env-file-if-exists=.env scripts/publish/bili/bili-meta.mjs",
    "bili:upload": "node scripts/publish/bili/bili-upload.mjs",
    "download-bili": "node scripts/publish/bili/download-bili.mjs",
    "postinstall": "node scripts/publish/bili/download-bili.mjs",
    "publish:bili": "bun run video:render && bun run render:cover && bun run bili:meta && bun run bili:upload",
    "all:bili": "bun run video:prepare && bun run publish:bili",
    "upgrade": "remotion upgrade",
    "lint": "eslint src scripts && tsc"
  },
  "sideEffects": [
    "*.css"
  ]
}
