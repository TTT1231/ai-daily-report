{
  // priorityEntities: 用户重点关注的厂商、模型或产品实体。
  // name 仅用于生成 AI 兴趣画像说明；aliases 用于本地确定性关键词匹配，建议全部使用常见标题写法。
  "priorityEntities": [
    {
      "name": "OpenAI / ChatGPT / GPT / Codex",
      "aliases": ["openai", "chatgpt", "gpt", "codex"]
    },
    {
      "name": "智谱 / GLM",
      "aliases": ["智谱", "glm"]
    },
    {
      "name": "月之暗面 / Kimi",
      "aliases": ["kimi", "月之暗面", "moonshot"]
    },
    {
      "name": "Anthropic / Claude",
      "aliases": ["claude", "anthropic"]
    },
    {
      "name": "DeepSeek / 深度求索",
      "aliases": ["deepseek", "深度求索"]
    },
    {
      "name": "Qwen / 通义千问",
      "aliases": ["qwen", "qween", "通义千问", "阿里云百炼", "阿里百炼"]
    }
  ],

  // signals: 用来判断“什么变化值得关注”的正向信号词。
  // 这些词同时用于本地保底评分和 AI 评分 Prompt，修改后两条评分路径会一起生效。
  "signals": {
    // priorityKeywords: 用户自定义的直接加分关键词。任意标题命中后获得 9 分本地保底，
    // 适合关注 MCP、特定开源项目或其他不属于 priorityEntities 的主题；不需要时可留空。
    "priorityKeywords": [],

    // aiTerms: 判断一条政策或行业新闻是否与 AI 直接相关。
    "aiTerms": ["ai", "人工智能", "大模型", "模型", "算法"],

    // importantChanges: 重点实体出现这些产品、能力、价格、权益或账号变化时，提高优先级。
    "importantChanges": [
      "发布", "开源", "上线", "开放", "api", "内测", "公测", "模型", "版本",
      "额度", "限额", "重置", "涨价", "降价", "价格", "消耗", "倍率",
      "封号", "被封", "风控", "收购", "agent", "智能体", "套餐", "规则",
      "信用卡", "服务", "功能", "更新"
    ],

    // riskEvents: 中转、订阅、账号或服务出现这些事件时，即使标题含低价等词也保留为风险情报。
    "riskEvents": [
      "跑路", "诈骗", "封号", "被封", "杀号", "风控", "关停", "关闭服务",
      "停止服务", "不可用", "上游限制", "余额无法", "掉订阅", "黑冲"
    ],

    // intermediaryTerms: 用于识别 API 中转、代充、拼车等渠道类内容。
    "intermediaryTerms": ["中转", "低价ai", "低价gpt", "低价claude", "代充", "拼车"],

    // intermediaryProducts: 风险事件还需命中这些 AI 服务或订阅词，才按渠道风险新闻保底召回。
    "intermediaryProducts": ["api", "中转", "gpt", "claude", "plus", "pro", "订阅"],

    // majorPolicy: 国家级 AI 政策、监管、执法和合规治理信号，命中后给予最高优先级。
    "majorPolicy": [
      "中央网信办", "国家网信办", "网信办", "国务院", "工信部",
      "清朗", "专项行动", "监管", "举报专区", "合规治理"
    ],

    // majorIndustryChanges: 非重点实体只有同时属于 AI 且出现这些行业级变化时，才允许高分进入。
    "majorIndustryChanges": [
      "重大收购", "合并", "国家标准", "行业标准", "全面禁止", "正式开源",
      "发布新模型", "发布并开源"
    ],

    // productImpact: 地缘政治类标题只有明确影响产品、API、价格、账号或服务可用性时才允许保留。
    "productImpact": [
      "api", "发布", "开源", "上线", "额度", "限额", "重置", "价格",
      "涨价", "降价", "内测", "公测", "封号", "被封", "服务关停",
      "禁用", "不可用", "停止服务", "禁止使用"
    ]
  },

  // dislikes: 用户明确不喜欢的内容。它们是硬排除词表，但风险事件和明确产品影响可按代码规则例外保留。
  "dislikes": {
    // hardExclude: 用户明确不想看到的关键词。任意标题命中后无条件排除；不需要时可留空。
    "hardExclude": [],

    // marketing: 广告、促销、卖号、拉新、抽奖等营销内容。
    "marketing": [
      "低价", "超低价", "限时优惠", "注册送", "拼车", "代充", "代购",
      "售卖", "出售", "购买", "返利", "邀请码", "推广", "渠道招募",
      "抽奖", "竞猜", "预测冠军", "抢万亿token", "签到送", "拉新", "邀请有礼"
    ],

    // geopolitics: 只有政治表态或地缘叙事、没有产品使用影响的内容。
    "geopolitics": [
      "地缘政治", "国家竞争", "中美竞争", "中美关系", "国际关系", "政治表态",
      "煽动", "舆论操纵", "影响美国", "削弱美国", "中国关联", "与中国有关联",
      "政治宣传", "政府指控", "制裁"
    ]
  },

  // guidance: 提供给 AI 评分器的自然语言兴趣说明，用于表达仅靠关键词难以描述的取舍。
  "guidance": {
    // focus: 希望 AI 主动关注的内容范围。
    "focus": [
      "重点实体的新模型、新版本、开源、API、能力、价格、额度、套餐、账号风险、地区可用性、重大收购和重要 Agent 或编程工具变化",
      "会显著影响 AI 行业发展的国家级政策、监管、执法、合规治理和行业格局变化",
      "API 中转站、低价 AI 渠道的大规模封号、跑路诈骗、服务关停、重大规则变化、上游限制和可用性危机"
    ],

    // notInterested: 希望 AI 主动降分的内容范围，用于补充 dislikes 关键词无法完整表达的语义。
    "notInterested": [
      "与 AI 无直接关系的泛科技、网络安全、硬件、云服务器、金融、航天、资本市场、社会新闻和科学趣闻",
      "普通软件发布、普通安全漏洞、无具体产品或政策影响的 AI 宣传稿、界面小改动、未经证实的版本猜测和标题党",
      "中转站广告、卖号、拼车、推广引流、优惠促销、邀请码、返利、拉新、抽奖和赠送 Token 活动"
    ]
  },

  // thresholds: 兴趣筛选阶段的可调阈值。
  "thresholds": {
    // minimumScore: 模型评分或本地保底评分达到该分数才进入候选，允许范围 1 至 10。
    "minimumScore": 7,

    // maximumCandidates: 聚类前最多保留的候选条数，避免一次模型请求内容过多。
    "maximumCandidates": 30
  }
}
