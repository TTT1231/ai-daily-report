# OpenAI-compatible chat completions model used by ingest/. All three are required.
# DeepSeek example values are shown below. To change providers, replace these three values.
AI_API_KEY=your-api-key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
AI_EXTRA_BODY_JSON={"response_format":{"type":"json_object"}}


# Optional provider-specific fields merged into every /chat/completions request.
# Recommended: force valid JSON output to avoid the scorer occasionally emitting
# malformed JSON (e.g. missing quotes around the reason field):
#   AI_EXTRA_BODY_JSON={"response_format":{"type":"json_object"}}
# Note: prompts request a top-level JSON array; even if a provider wraps it in an
# object under json_object mode (e.g. {"items":[...]}), the parser extracts the
# inner array, so this default stays safe across providers.
# Example: AI_EXTRA_BODY_JSON={"temperature":0}
# AI_EXTRA_BODY_JSON=

# Optional RSS config path overrides. Normal usage edits the default JSONC files directly.
# RSS_SOURCES_PATH=C:\path\to\sources.jsonc
# RSS_PREFERENCES_PATH=C:\path\to\preferences.jsonc

# Optional outbound proxy for RSS feeds and AI model requests.
# Leave unset for direct access. When set, requests must use this proxy.
# Supports http, https, socks5, and socks5h. Only lowercase all_proxy is read.
all_proxy=http://127.0.0.1:7890

# Optional Claude remote-image enrichment.
# CLAUDE_VISION_ENABLED=true
# CLAUDE_VISION_MAX_CALLS=4
# CLAUDE_VISION_MAX_IMAGES_PER_SOURCE=2
# CLAUDE_VISION_TEXT_THRESHOLD=500
# CLAUDE_VISION_TIMEOUT_SECONDS=180
# CLAUDE_VISION_MAX_BUDGET_USD=1.00

# MiniMax TTS.
MINIMAX_API_KEY=your-api-key
MINIMAX_TTS_ENDPOINT=https://api.minimaxi.com/v1/t2a_v2
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_VOICE_ID=Chinese_sweet_girl_vv1
MINIMAX_TTS_SPEED=1.18
TTS_TAIL_PADDING_MS=200

