# OpenAI Chat Completions API 格式，仅在 ingest/ 和 bili:meta 使用。
AI_API_KEY=<your-api-key>
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
AI_EXTRA_BODY_JSON={"response_format":{"type":"json_object"}}

# 调用 linux.do 网络受限时需要科学上网环境；留空或删除则 rss 阶段直连。例如all_proxy=http://127.0.0.1:7890
all_proxy=<your-network-proxy>

# 图片识别 / 配图（需要 Claude CLI 支持多模态，或配置图片识别 MCP）。
CLAUDE_VISION_ENABLED=true                # true：默认优先处理高分且含远程图的 Story；受调用上限/预算控制，判定相关后才写入 scene.overlayImg。false：不识图、不自动写 overlayImg；但会把高分 Story 的候选图下载到 data-scheme/images/，供手动配图。
CLAUDE_VISION_MAX_CALLS=4                 # 整个 rss 过程最多识图次数
CLAUDE_VISION_MAX_IMAGES_PER_SOURCE=2     # 单条新闻 / 单个 scene 最多候选图数量
CLAUDE_VISION_TIMEOUT_SECONDS=180         # 单次识图调用 Claude 超时时间
CLAUDE_VISION_MAX_BUDGET_USD=1.00         # 单次识图调用美元预算上限

# TTS（MiniMax）。
# false：整个 TTS 子系统跳过，不调用 MiniMax，不生成音频，也不跑 ffmpeg 音质检测。
TTS_REQUIRE=true
MINIMAX_API_KEY=<your-api-key>
MINIMAX_TTS_ENDPOINT=https://api.minimaxi.com/v1/t2a_v2
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_VOICE_ID=Chinese_sweet_girl_vv1
MINIMAX_TTS_SPEED=1.18
TTS_TAIL_PADDING_MS=200

# ffmpeg 语音质量检测（检测孤立爆音 / click）。没装 ffmpeg 时可设为 false，TTS 仍会生成。
REQUIRE_VOICE_QUALITY_FFMPEG=true
